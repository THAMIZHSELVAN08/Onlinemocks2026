// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HR
  VOLUNTEER
  PIPELINE
  STUDENT
}

enum NotificationType {
  TRANSFER
  EVALUATION
  GENERAL
}

enum InterviewStatus {
  PENDING
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String
  role         Role
  plainPassword String? @map("plain_password")
  createdAt    DateTime @default(now())

  hrProfile        HrProfile?
  volunteerProfile VolunteerProfile?
  pipelineProfile  PipelineProfile?

  evaluationsGiven Evaluation[]      @relation("HrEvaluations")
  transfersFrom    StudentTransfer[] @relation("TransferFromHr")
  transfersTo      StudentTransfer[] @relation("TransferToHr")

  transfersAsAdmin StudentTransfer[] @relation("TransferAdmin")
  notifications    Notification[]    @relation("ReceiverNotifications")
  hrAssignments    HrAssignment[]

  feedbacks Feedback[] // ← ADD THIS
  volunteerFeedbacks VolunteerFeedback[] @relation("VolunteerFeedbacks")
}

model PipelineProfile {
  id    String  @id @db.Uuid
  name  String? @db.VarChar(255)

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("pipeline_profiles")
}

model Student {
  id             String  @id @default(uuid()) @db.Uuid
  name           String?
  registerNumber String  @unique
  department     String?
  section        String?
  resumeUrl      String?
  aptitudeScore  Int     @default(0)
  gdScore        Int     @default(0)

  assignments      HrAssignment[]
  evaluations      Evaluation[]
  studentTransfers StudentTransfer[]
}

model HrProfile {
  id          String  @id @db.Uuid
  name        String? @db.VarChar(255)
  companyName String? @map("company_name") @db.VarChar(255)

  user       User               @relation(fields: [id], references: [id], onDelete: Cascade)
  volunteers VolunteerProfile[] @relation("HrVolunteers")

  @@map("hr_profiles")
}

model VolunteerProfile {
  id           String  @id @db.Uuid
  name         String? @db.VarChar(255)
  assignedHrId String? @map("assigned_hr_id") @db.Uuid

  user       User       @relation(fields: [id], references: [id], onDelete: Cascade)
  assignedHr HrProfile? @relation("HrVolunteers", fields: [assignedHrId], references: [id], onDelete: SetNull)

  @@map("volunteer_profiles")
}

model HrAssignment {
  id         Int             @id @default(autoincrement())
  hrId       String          @db.Uuid
  studentId  String          @db.Uuid
  order      Int
  status     InterviewStatus @default(PENDING)
  assignedAt DateTime        @default(now())

  hr      User    @relation(fields: [hrId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([hrId, order])
  @@index([hrId])
  @@index([studentId])
}

model Evaluation {
  id                  Int       @id @default(autoincrement())
  studentId           String    @db.Uuid
  hrId                String    @db.Uuid
  appearanceAttitude  Int       @default(0) @map("appearance_attitude")
  managerialAptitude  Int       @default(0) @map("managerial_aptitude")
  generalAwareness    Int       @default(0) @map("general_awareness")
  technicalKnowledge  Int       @default(0) @map("technical_knowledge")
  communicationSkills Int       @default(0) @map("communication_skills")
  ambition            Int       @default(0)
  selfConfidence      Int       @default(0) @map("self_confidence")
  strengths           String?
  improvements        String?
  comments            String?
  overallScore        Decimal?  @map("overall_score") @db.Decimal(4, 2)
  evaluationDate      DateTime? @default(now()) @map("evaluation_date") @db.Date
  createdAt           DateTime  @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  hr      User?   @relation("HrEvaluations", fields: [hrId], references: [id])

  @@unique([studentId, hrId])
  @@map("evaluations")
}

model StudentTransfer {
  id             Int      @id @default(autoincrement())
  studentId      String   @map("student_id") @db.Uuid
  fromHrId       String?  @map("from_hr_id") @db.Uuid
  toHrId         String?  @map("to_hr_id") @db.Uuid
  adminId        String?  @map("admin_id") @db.Uuid
  transferReason String?  @map("transfer_reason")
  transferredAt  DateTime @default(now()) @map("transferred_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromHr  User?   @relation("TransferFromHr", fields: [fromHrId], references: [id])
  toHr    User?   @relation("TransferToHr", fields: [toHrId], references: [id])
  admin   User?   @relation("TransferAdmin", fields: [adminId], references: [id])

  @@map("student_transfers")
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  receiverId String           @map("receiver_id") @db.Uuid
  title      String?
  message    String
  type       NotificationType @default(GENERAL)
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at")

  receiver User @relation("ReceiverNotifications", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Feedback {
  id                     Int      @id @default(autoincrement())
  hrId                   String   @db.Uuid
  technicalKnowledge     Int
  serviceAndCoordination Int      @map("service_and_coordination")
  communicationSkills    Int      @map("communication_skills")
  futureParticipation    Int      @map("future_participation")
  punctualityAndInterest Int      @map("punctuality_and_interest")
  suggestions            String?
  issuesFaced            String?  @map("issues_faced")
  improvementSuggestions String?  @map("improvement_suggestions")
  submittedAt            DateTime @default(now()) @map("submitted_at")

  hr User @relation(fields: [hrId], references: [id], onDelete: Cascade)

  @@index([hrId])
  @@map("feedbacks")
}

model VolunteerFeedback {
  id                      Int      @id @default(autoincrement())
  volunteerId             String   @db.Uuid @map("volunteer_id")
  clarityOfInstructions   Int      @map("clarity_of_instructions")
  hrCooperation           Int      @map("hr_cooperation")
  organizationOfSchedule  Int      @map("organization_of_schedule")
  softwareEase            Int      @map("software_ease")
  workloadManagement      Int      @map("workload_management")
  overallExperience       Int      @map("overall_experience")
  issuesFaced             String?  @map("issues_faced")
  improvementSuggestions  String?  @map("improvement_suggestions")
  additionalComments      String?  @map("additional_comments")
  submittedAt             DateTime @default(now()) @map("submitted_at")

  volunteer User @relation("VolunteerFeedbacks", fields: [volunteerId], references: [id], onDelete: Cascade)

  @@index([volunteerId])
  @@map("volunteer_feedbacks")
}
